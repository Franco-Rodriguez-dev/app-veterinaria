      "MascotaMiniDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "raza": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PersonaCreateDTO": {
        "required": [
          "apellido",
          "nombre",
          "sexo",
          "telefono"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 20,
            "minLength": 0,
            "pattern": "^[a-zA-ZáéíóúÁÉÍÓÚñÑ\\s]+$",
            "type": "string"
          },
          "apellido": {
            "maxLength": 20,
            "minLength": 0,
            "pattern": "^[a-zA-ZáéíóúÁÉÍÓÚñÑ\\s]+$",
            "type": "string"
          },
          "edad": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "sexo": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "telefono": {
            "minLength": 1,
            "pattern": "^(\\+54|0)?[0-9]{8,15}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PersonaDetalleDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "apellido": {
            "type": "string",
            "nullable": true
          },
          "edad": {
            "type": "integer",
            "format": "int32"
          },
          "sexo": {
            "$ref": "#/components/schemas/Sexo"
          },
          "telefono": {
            "type": "string",
            "nullable": true
          },
          "listaMascotas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MascotaMiniDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PersonaListsDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "apellido": {
            "type": "string",
            "nullable": true
          },
          "edad": {
            "type": "integer",
            "format": "int32"
          },
          "telefono": {
            "type": "string",
            "nullable": true
          },
          "cantMascotas": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PersonaMascotaCreateDTO": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "apellido": {
            "type": "string",
            "nullable": true
          },
          "telefono": {
            "type": "string",
            "nullable": true
          },
          "edad": {
            "type": "integer",
            "format": "int32"
          },
          "sexo": {
            "type": "string",
            "nullable": true
          },
          "mascota": {
            "$ref": "#/components/schemas/MascotaCreateDTO"
          }
        },
        "additionalProperties": false
      },
      "PersonaUpdateDTO": {
        "required": [
          "apellido",
          "nombre",
          "sexo",
          "telefono"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 20,
            "minLength": 0,
            "pattern": "^[a-zA-ZáéíóúÁÉÍÓÚñÑ\\s]+$",
            "type": "string"
          },
          "apellido": {
            "maxLength": 20,
            "minLength": 0,
            "pattern": "^[a-zA-ZáéíóúÁÉÍÓÚñÑ\\s]+$",
            "type": "string"
          },
          "edad": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "sexo": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "telefono": {
            "minLength": 1,
            "pattern": "^(\\+54|0)?[0-9]{8,15}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Sexo": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Ingresá el token así: Bearer {tu_token}",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
